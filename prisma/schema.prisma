generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ─── Enums ───────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  ESCROW_LOCKED
  SENT_TO_PROVIDER
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  ESCROW_RELEASED
  DISPUTED
  CANCELLED
  REFUNDED
}

enum EscrowStatus {
  LOCKING
  LOCK_FAILED
  LOCKED
  RELEASING
  RELEASED
  DISPUTED
  REFUNDING
  REFUNDED
  EXPIRED
}

enum NftStatus {
  MINTING
  MINTED
  TRANSFERRED
  BURNED
  MINT_FAILED
}

enum PhysicalStatus {
  IN_PRODUCTION
  SHIPPED
  DELIVERED
}

// ─── Models ──────────────────────────────────────────────────────────

model Store {
  id             String   @id @default(uuid())
  shopifyDomain  String   @unique
  shopifyToken   String
  name           String
  email          String
  plan           String   @default("free")
  // Owner wallet used for SIWS auth. Unique — one wallet = one store.
  walletAddress  String?  @unique
  // Payout destination for escrow releases. Defaults to walletAddress on link; editable.
  stellarAddress String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  designs          Design[]
  orders           Order[]
  escrows          Escrow[]
  storeProviders   StoreProvider[]
  webhookLogs      WebhookLog[]
  merchantProducts MerchantProduct[]
  settings         StoreSettings?
  storeIssuer      StoreIssuer?
  nfts             NftToken[]
  trendDesigns       TrendDesign[]
  subscriptionLocks  SubscriptionPriceLock[]
  subscription       Subscription?
  trendQuotas        TrendQuota[]
}

model Provider {
  id             String   @id @default(uuid())
  name           String
  country        String
  contactEmail   String   @unique
  stellarAddress String
  verified       Boolean  @default(false)
  rating         Float    @default(0)
  totalOrders    Int      @default(0)
  completionRate Float    @default(0)
  specialties    String[]
  minOrderQty    Int      @default(1)
  avgLeadDays    Int      @default(7)
  passwordHash   String?
  lastLoginAt    DateTime?
  apiKey         String?   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // External provider integration
  integrationType   String?   // 'printful' | 'printify' | 'gooten' | 'manual'
  externalId        String?   // Provider's own merchant/shop ID
  // AES-256-GCM ciphertext (format: iv:authTag:ciphertext, all hex).
  // Encrypted at write time by ProvidersService.setupIntegration; decrypted
  // on use via ProvidersService.decryptProviderToken. Legacy plaintext rows
  // from before encryption was wired up are tolerated but logged as a
  // warning — re-running setupIntegration re-encrypts them.
  apiToken          String?
  apiSecret         String?
  webhookSecret     String?   // For verifying incoming webhooks
  integrationStatus String?   @default("pending") // pending | active | paused | error
  lastSyncedAt      DateTime?
  syncError         String?

  orders           Order[]
  escrows          Escrow[]
  storeProviders   StoreProvider[]
  products         ProviderProduct[]
  providerOrders   ProviderOrder[]
  settings         ProviderSettings?
}

model StoreProvider {
  id         String  @id @default(uuid())
  storeId    String
  providerId String
  status     String  @default("pending")
  agreedRate Float?

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([storeId, providerId])
}

model Design {
  id               String    @id @default(uuid())
  storeId          String
  name             String
  fileUrl          String
  thumbnailUrl     String?
  fileSha256       String
  fileSizeBytes    Int
  mimeType         String
  width            Int?
  height           Int?
  copyrightTxHash  String?
  copyrightLedger  Int?
  copyrightAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  store            Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  mockups          Mockup[]
  orderItems       OrderItem[]
  merchantProducts MerchantProduct[]
  nfts             NftToken[]
  trendDesigns     TrendDesign[]

  @@index([storeId])
  @@index([fileSha256])
}

model Mockup {
  id          String   @id @default(uuid())
  designId    String
  productType String
  variant     String
  imageUrl    String
  createdAt   DateTime @default(now())

  design Design @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@unique([designId, productType, variant])
  @@index([designId])
}

model Order {
  id                 String      @id @default(uuid())
  storeId            String
  providerId         String?
  shopifyOrderId     String
  shopifyOrderNumber String
  shopifyOrderGid    String?
  status             OrderStatus @default(PENDING)
  customerName       String
  shippingAddress    Json
  trackingNumber     String?
  trackingUrl        String?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  subtotalUsdc       Float
  platformFeeUsdc    Float
  providerPayUsdc    Float
  totalUsdc          Float
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  isBurnOrder    Boolean         @default(false)
  burnNftId      String?

  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  provider       Provider?       @relation(fields: [providerId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  escrows        Escrow[]
  providerOrders ProviderOrder[]
  nfts           NftToken[]

  @@unique([storeId, shopifyOrderId])
  @@index([storeId])
  @@index([providerId])
  @@index([status])
}

model OrderItem {
  id          String @id @default(uuid())
  orderId     String
  designId    String?
  productType String
  variant     String
  quantity    Int
  unitPrice   Float

  order  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  design Design? @relation(fields: [designId], references: [id], onDelete: SetNull)
  nft    NftToken?

  @@index([orderId])
}

model Escrow {
  id               String       @id @default(uuid())
  orderId          String
  storeId          String
  providerId       String?
  providerOrderId  String?      @unique
  status           EscrowStatus @default(LOCKING)
  contractId     String?
  lockTxHash     String?
  releaseTxHash  String?
  refundTxHash   String?
  amountUsdc     Float
  platformFee    Float
  providerAmount Float
  lockedAt       DateTime?
  releasedAt     DateTime?
  expiresAt      DateTime
  retryCount     Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  provider Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  disputes Dispute[]

  @@index([orderId])
  @@index([storeId])
  @@index([status])
  @@index([providerId])
  @@index([expiresAt])
}

model Dispute {
  id         String    @id @default(uuid())
  escrowId   String
  raisedBy   String
  reason     String
  evidence   Json?
  resolution String?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  escrow Escrow @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@index([escrowId])
}

model WebhookLog {
  id               String    @id @default(uuid())
  storeId          String
  shopifyWebhookId String    @unique
  topic            String
  payload          Json
  processedAt      DateTime?
  error            String?
  createdAt        DateTime  @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([createdAt])
}

model StellarTransaction {
  id          String   @id @default(uuid())
  txHash      String   @unique
  ledger      Int
  type        String
  fromAddress String
  toAddress   String?
  amountUsdc  Float?
  memo        String?
  status      String   @default("pending")
  rawXdr      String?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([fromAddress])
}

// ─── MERCHANT PRODUCT (Shopify <-> Design <-> Provider mapping) ────

model MerchantProduct {
  id                 String    @id @default(uuid())
  storeId            String
  designId           String
  providerProductId  String
  shopifyProductId   String?   // Numeric Shopify product ID
  shopifyProductGid  String?   // GraphQL GID: gid://shopify/Product/xxx
  title              String
  description        String?
  retailPrice        Float     // What the customer pays
  baseCost           Float     // What the provider charges
  profitMargin       Float     // retailPrice - baseCost - platformFee
  printConfig        Json      // { printArea, x, y, scale, rotation }
  status             String    @default("draft") // draft, publishing, published, error
  publishedAt        DateTime?
  isBurnToClaim      Boolean   @default(false)
  maxSupply          Int?
  seoTitle       String?
  seoDescription String?
  seoTags        String[]
  seoHandle      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  store              Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  design             Design    @relation(fields: [designId], references: [id])
  providerProduct    ProviderProduct @relation(fields: [providerProductId], references: [id])
  nfts               NftToken[]

  @@index([storeId])
  @@index([shopifyProductId])
  @@map("merchant_products")
}

model ProviderProduct {
  id              String   @id @default(uuid())
  providerId      String
  productType     String   // "t-shirt", "hoodie", "mug", "poster", "tote-bag"
  name            String   // "Bella+Canvas 3001 Unisex Jersey Tee"
  brand           String?
  description     String?
  baseCost        Float    // USD base cost per unit
  printAreas      Json     // [{ name: "front", widthPx: 4200, heightPx: 4800, dpi: 300 }, { name: "back", widthPx: 4200, heightPx: 4800, dpi: 300 }]
  blankImages     Json     // { "Black": "https://...", "White": "https://..." }
  sizeChart       Json?    // { "S": { "chest_cm": 86, "length_cm": 71 }, "M": { ... } }
  weightGrams     Float?   // per unit weight for shipping calc
  productionDays  Int      @default(3)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // External provider mapping
  externalProductId String?   // Provider API's product ID (e.g. Printful product_id)
  externalCatalogId String?   // Provider catalog ID for ordering
  syncedAt          DateTime?

  provider         Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  variants         ProviderProductVariant[]
  merchantProducts MerchantProduct[]

  @@index([providerId])
  @@index([productType])
  @@map("provider_products")
}

model ProviderProductVariant {
  id                String  @id @default(uuid())
  providerProductId String
  size              String  // "S", "M", "L", "XL", "2XL"
  color             String  // "Black", "White", "Navy"
  colorHex          String? // "#000000"
  sku               String  // Provider's internal SKU
  additionalCost    Float   @default(0) // Extra cost for 2XL+ sizes
  inStock           Boolean @default(true)

  externalVariantId String?  // Provider API's variant ID

  providerProduct   ProviderProduct @relation(fields: [providerProductId], references: [id], onDelete: Cascade)

  @@unique([providerProductId, size, color])
  @@index([providerProductId])
  @@map("provider_product_variants")
}

model ProviderOrder {
  id              String   @id @default(uuid())
  orderId         String
  providerId      String
  status          String   @default("pending")
  // pending → accepted → printing → quality_check → packing → shipped → delivered
  totalBaseCost   Float
  platformFee     Float
  trackingNumber  String?
  trackingUrl     String?
  trackingCompany String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  designFileUrls  Json?    // URLs of print-ready files for this sub-order
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // External provider mapping
  externalOrderId String?   // Provider API's order ID
  externalOrderUrl String?  // Link to provider dashboard
  submittedAt     DateTime?
  submissionError String?

  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider        Provider @relation(fields: [providerId], references: [id])

  @@index([orderId])
  @@index([providerId])
  @@index([status])
  @@map("provider_orders")
}

// ─── Settings + Notifications Platform ──────────────────────────────

model StoreSettings {
  id            String   @id @default(uuid())
  storeId       String   @unique
  // Store
  storeName     String?
  locale        String   @default("en") // 'en' | 'vi'
  // Webhook
  webhookUrl    String?
  webhookSecret String?
  webhookSecretPrev String?
  webhookSecretRotatedAt DateTime?
  webhookEvents String[] @default([])
  webhookActiveSince DateTime?
  webhookFailureCount Int @default(0)
  webhookDisabledAt   DateTime?
  webhookDisabledReason String?
  // Pricing
  defaultMarkup Float    @default(30)
  // Category toggles (6 categories)
  notifyOrders   Boolean @default(true)
  notifyEscrow   Boolean @default(true)
  notifyShipping Boolean @default(true)
  notifyDisputes Boolean @default(true)
  notifyProducts Boolean @default(true)
  notifySystem   Boolean @default(true)
  // Channel toggles
  notificationEmail String?
  emailEnabled      Boolean @default(true)
  inAppEnabled      Boolean @default(true)
  webhookEnabled    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("store_settings")
}

model ProviderSettings {
  id            String   @id @default(uuid())
  providerId    String   @unique
  locale        String   @default("en")
  // Webhook
  webhookUrl    String?
  webhookSecret String?
  webhookSecretPrev String?
  webhookSecretRotatedAt DateTime?
  webhookFailureCount Int @default(0)
  webhookDisabledAt   DateTime?
  webhookDisabledReason String?
  // Category toggles
  notifyNewOrders     Boolean @default(true)
  notifyOrderCancelled Boolean @default(true)
  notifyEscrowReleased Boolean @default(true)
  notifyDisputes      Boolean @default(true)
  notifySystem        Boolean @default(true)
  // Channel toggles
  notificationEmail String?
  emailEnabled      Boolean @default(true)
  inAppEnabled      Boolean @default(true)
  webhookEnabled    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  provider  Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_settings")
}

model Notification {
  id            String   @id @default(uuid())
  // Polymorphic recipient — exactly ONE of these
  recipientType String   // 'store' | 'provider'
  recipientId   String
  // Idempotency
  eventId       String?  // EventOutbox.id
  type          String   // 'order_created', etc.
  category      String   // 'orders' | 'escrow' | 'shipping' | 'disputes' | 'products' | 'system'
  title         String
  message       String
  payload       Json
  link          String?
  // Actor + relation tracking
  actorType     String?
  actorId       String?
  relatedType   String?
  relatedId     String?
  // Grouping
  groupKey      String?
  // Lifecycle
  readAt        DateTime?
  createdAt     DateTime @default(now())

  @@unique([eventId, recipientType, recipientId])
  @@index([recipientType, recipientId, readAt])
  @@index([recipientType, recipientId, createdAt])
  @@index([recipientType, recipientId, groupKey])
  @@index([relatedType, relatedId])
  @@index([createdAt])
  @@map("notifications")
}

model WebhookDelivery {
  id              String   @id @default(uuid())
  requestId       String   @default(uuid()) @unique
  recipientType   String   // 'store' | 'provider'
  recipientId     String
  notificationId  String?
  url             String
  eventType       String
  payload         Json
  signature       String?
  status          String   @default("pending") // pending | success | failed | retrying
  attempts        Int      @default(0)
  maxAttempts     Int      @default(5)
  lastAttemptAt   DateTime?
  nextRetryAt     DateTime?
  responseStatus  Int?
  responseBody    String?
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([recipientType, recipientId, createdAt])
  @@index([status, nextRetryAt])
  @@index([requestId])
  @@index([createdAt])
  @@map("webhook_deliveries")
}

model EventOutbox {
  id          String   @id @default(uuid())
  eventType   String
  payload     Json
  storeId     String?
  providerId  String?
  status      String   @default("pending") // pending | processing | processed | failed
  attempts    Int      @default(0)
  maxAttempts Int      @default(5)
  lastError   String?
  createdAt   DateTime @default(now())
  processedAt DateTime?

  @@index([status, createdAt])
  @@index([eventType])
  @@index([storeId])
  @@index([providerId])
  @@index([processedAt])
  @@map("event_outbox")
}

model NotificationSession {
  id            String   @id @default(uuid())
  recipientType String   // 'store' | 'provider'
  recipientId   String
  token         String   @unique
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([token, expiresAt])
  @@index([expiresAt])
  @@map("notification_sessions")
}

// ─── Digital Twin NFT ───────────────────────────────────────────────

model StoreIssuer {
  id                 String    @id @default(uuid())
  storeId            String    @unique
  store              Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  stellarPublicKey   String    @unique
  encryptedSecretKey String
  fundedAt           DateTime?
  createdAt          DateTime  @default(now())

  @@map("store_issuers")
}

model BuyerWallet {
  id                 String    @id @default(uuid())
  email              String    @unique
  stellarPublicKey   String    @unique
  encryptedSecretKey String
  fundedAt           DateTime?
  claimedAt          DateTime?
  claimWalletAddress String?
  nfts               NftToken[]
  createdAt          DateTime  @default(now())

  @@map("buyer_wallets")
}

model NftToken {
  id                String          @id @default(uuid())
  orderId           String
  order             Order           @relation(fields: [orderId], references: [id])
  orderItemId       String          @unique
  orderItem         OrderItem       @relation(fields: [orderItemId], references: [id])
  merchantProductId String
  merchantProduct   MerchantProduct @relation(fields: [merchantProductId], references: [id])
  designId          String
  design            Design          @relation(fields: [designId], references: [id])
  storeId           String
  store             Store           @relation(fields: [storeId], references: [id])

  assetCode         String
  issuerPublicKey   String
  ownerWalletId     String?
  ownerWallet       BuyerWallet?    @relation(fields: [ownerWalletId], references: [id])

  metadataUrl       String
  metadataHash      String

  mintTxHash        String?
  mintLedger        Int?
  burnTxHash        String?
  deliveryTxHash    String?

  status            NftStatus       @default(MINTING)
  physicalStatus    PhysicalStatus?
  serialNumber      Int             @unique @default(autoincrement())
  burnedAt          DateTime?
  burnOrderId       String?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([storeId])
  @@index([orderId])
  @@index([merchantProductId])
  @@index([ownerWalletId])
  @@map("nft_tokens")
}

// ─── Trend Suggestions ──────────────────────────────────────────────

enum CopyrightRisk {
  LOW
  MEDIUM
  HIGH
  BLOCKED
}

enum TrendSource {
  REDDIT
  TWITTER
  PINTEREST
  TIKTOK
  GOOGLE_TRENDS
}

enum TrendDesignStatus {
  PENDING
  GENERATING
  UPSCALING
  COMPOSITING
  COMPLETED
  FAILED
}

model Niche {
  id              String   @id @default(uuid())
  slug            String   @unique
  name            String
  emoji           String
  description     String
  redditSubs      String[]
  twitterHashtags String[]
  pinterestQuery  String
  tiktokHashtags  String[]
  enabled         Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  @@map("niches")
}

model TrendItem {
  id                    String              @id @default(uuid())
  source                TrendSource
  sourceId              String
  sourceUrl             String?
  niche                 String
  keyword               String
  fullText              String?
  language              String              @default("en")
  styleRefs             Json?
  sellabilityScore      Int
  emotionTags           String[]
  visualPotential       Int
  copyrightRisk         CopyrightRisk
  copyrightFlags        String[]
  copyrightSearchHits   Json?
  viralityScore         Int
  engagementCount       Int?
  growthVelocity        Float?
  embedding             Unsupported("vector(768)")?
  fetchedAt             DateTime            @default(now())
  expiresAt             DateTime
  generatedDesigns      TrendDesign[]

  @@index([niche, sellabilityScore])
  @@index([expiresAt])
  @@unique([source, sourceId])
  @@map("trend_items")
}

model TrendDesign {
  id                    String            @id @default(uuid())
  trendItemId           String
  trendItem             TrendItem         @relation(fields: [trendItemId], references: [id])
  designId              String?
  design                Design?           @relation(fields: [designId], references: [id])
  storeId               String
  store                 Store             @relation(fields: [storeId], references: [id])
  promptUsed            String
  styleUsed             Json?
  status                TrendDesignStatus @default(PENDING)
  errorMessage          String?
  attempts              Int               @default(0)
  generationDurationMs  Int?
  startedAt             DateTime          @default(now())
  completedAt           DateTime?

  @@index([storeId, status])
  @@map("trend_designs")
}

model SubscriptionPriceLock {
  id              String    @id @default(uuid())
  storeId         String
  store           Store     @relation(fields: [storeId], references: [id])
  periodMonths    Int
  currency        String
  amountUsdc      Float
  amountInCurrency Float
  xlmRate         Float?
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([storeId, expiresAt])
  @@map("subscription_price_locks")
}

model Subscription {
  id              String    @id @default(uuid())
  storeId         String    @unique
  store           Store     @relation(fields: [storeId], references: [id])
  plan            String
  periodMonths    Int
  currency        String
  amountPaid      Float
  amountUsdc      Float
  txHash          String    @unique
  ledger          Int
  startsAt        DateTime  @default(now())
  expiresAt       DateTime
  status          String
  autoRenew       Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@index([expiresAt])
  @@map("subscriptions")
}

model TrendQuota {
  id                String   @id @default(uuid())
  storeId           String
  store             Store    @relation(fields: [storeId], references: [id])
  date              DateTime @db.Date
  trendsViewed      Int      @default(0)
  designsGenerated  Int      @default(0)

  @@unique([storeId, date])
  @@map("trend_quotas")
}
